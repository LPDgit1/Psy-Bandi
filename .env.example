# Shared local defaults. Copy to .env only if you run with Docker Compose.
POSTGRES_DB=bandi
POSTGRES_USER=bandi
POSTGRES_PASSWORD=

DATABASE_URL=
APP_ENV=local
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_API_TOKEN=
PUBLIC_BASE_URL=http://localhost:5173
PUBLIC_API_BASE_URL=http://localhost:8000/api/public
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
INPA_IMPORT_ON_STARTUP=true
INSTITUTIONAL_IMPORT_ON_STARTUP=true
INPA_VERIFY_TLS=true
INPA_OPEN_SCAN_ENABLED=true
INPA_OPEN_SCAN_MAX_PAGES=50
SOURCE_IMPORT_VERIFY_TLS=true
SOURCE_PROBE_VERIFY_TLS=true
REMOVE_DEMO_ON_STARTUP=true
INPA_SEARCH_TERMS=psicolog,psicoterap,neuropsicolog,lm-51,albo psicologi,psicodiagnostic,valutazione psicologica,test neuropsicologici,riabilitazione cognitiva,psicopedagog,psicoeduc,psicosocial,salute mentale
INPS_SEARCH_TERMS=psicolog,psicoterap,neuropsicolog,lm-51,albo psicologi,psicodiagnostic,valutazione psicologica,test neuropsicologici,riabilitazione cognitiva,psicopedagog,psicoeduc,psicosocial,salute mentale
INPS_PAGE_SIZE=25
INPS_MAX_PAGES=3
INAIL_MAX_PAGES=3
AZIENDA_ZERO_PIEMONTE_MAX_PAGES=8
ASUIT_MAX_PAGES=8
AUSL_ROMAGNA_MAX_PAGES=4
CATALOG_MAX_DETAIL_LINKS_PER_SOURCE=4
DEEP_ADAPTER_MAX_LINKS_PER_SOURCE=24
DEEP_ADAPTER_BUDGET_SECONDS=300
PUBLIC_REFRESH_COOLDOWN_SECONDS=300
ALERT_SCHEDULER_ENABLED=true
ALERT_SCHEDULER_INITIAL_DELAY_SECONDS=60
ALERT_SCHEDULER_INTERVAL_SECONDS=3600
EMAIL_DELIVERY_MODE=file
EMAIL_FROM=Bandi Psicologia <noreply@example.test>
EMAIL_OUTBOX_DIR=tmp/email_outbox
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

VITE_API_BASE_URL=http://localhost:8000
